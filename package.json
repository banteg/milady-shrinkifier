{
  "name": "milady-shrinkifier",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:app && pnpm run build:worker && pnpm run build:content",
    "build:app": "vite build",
    "build:review": "vite build --config vite.review.config.ts",
    "build:worker": "esbuild src/worker.ts --bundle --format=iife --platform=browser --target=es2022 --sourcemap --outfile=dist/worker.js",
    "build:content": "esbuild src/content.ts --bundle --format=iife --platform=browser --target=es2022 --sourcemap --outfile=dist/content.js",
    "dev": "vite build --watch",
    "download:images": "tsx scripts/download-images.ts",
    "download:images:aria2": "zsh scripts/download-images-aria2.sh",
    "debug:chrome:attach": "node scripts/attach-debug-chrome.mjs",
    "debug:chrome:attach:keep-open": "node scripts/attach-debug-chrome.mjs --keep-open",
    "debug:chrome:launch-local-profile": "node scripts/launch-debug-chrome.mjs --local-profile",
    "debug:chrome:launch-extension-profile": "node scripts/launch-debug-chrome.mjs --system-profile-name Extension",
    "debug:extension": "node scripts/debug-extension.mjs",
    "debug:extension:default-profile": "node scripts/debug-extension.mjs --system-profile-default",
    "debug:extension:extension-profile": "node scripts/debug-extension.mjs --system-profile-name Extension",
    "debug:extension:seed-extension-profile": "node scripts/debug-extension.mjs --seed-from-system-profile-name Extension",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/solid-query": "^5.95.2",
    "@tanstack/solid-virtual": "^3.13.23",
    "onnxruntime-web": "^1.24.3",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.29",
    "@types/node": "^24.10.1",
    "esbuild": "^0.27.0",
    "jsdom": "^27.2.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^4.1.2"
  }
}
